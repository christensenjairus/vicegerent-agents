diff --git a/crates/agentgateway/src/llm/types/mod.rs b/crates/agentgateway/src/llm/types/mod.rs
index 0ff37d9..3805e58 100644
--- a/crates/agentgateway/src/llm/types/mod.rs
+++ b/crates/agentgateway/src/llm/types/mod.rs
@@ -26,6 +26,14 @@ pub trait ResponseType: Send + Sync {
 		resp: Vec<crate::llm::policy::webhook::ResponseChoice>,
 	) -> anyhow::Result<()>;
 	fn serialize(&self) -> serde_json::Result<Vec<u8>>;
+
+	/// Rewrite only the plain-text portions of this response in place. See
+	/// `RequestType::mask_text_content` for the full rationale -- same lossy round-trip
