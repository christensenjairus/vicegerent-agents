+#[cfg(test)]
+mod mask_text_content_tests {
+	use super::*;
+	use crate::llm::RequestType as _;
+
+	/// Regression test for the corruption this patch fixes: a request where one message
+	/// is entirely `tool_result` content (the normal shape of every user turn immediately
+	/// following a tool call in the Anthropic Messages API) must survive masking untouched
+	/// -- its content must remain a structured array, never collapse to an empty string.
+	#[test]
+	fn mask_preserves_tool_result_only_message() {
+		let mut req = Request {
+			messages: vec![
+				RequestMessage {
+					role: "user".to_string(),
+					content: Some(ContentBlock::Array(vec![ContentPart::Unknown(
+						serde_json::json!({
+							"type": "tool_result",
+							"tool_use_id": "toolu_01abc",
+							"content": "some tool output, unrelated to any secret",
+						}),
+					)])),
+					rest: Default::default(),
+				},
+				RequestMessage {
+					role: "user".to_string(),
+					content: Some(ContentBlock::Text(
+						"here is a key: sk-ant-abcdefghijklmnopqrstuvwxyz0123456789".to_string(),
+					)),
+					rest: Default::default(),
+				},
+			],
+			..Default::default()
+		};
+
+		let mut masked_any = false;
+		let changed = req.mask_text_content(&mut |text: &str| {
+			if text.contains("sk-ant-") {
+				masked_any = true;
+				Some("<masked>".to_string())
+			} else {
+				None
+			}
+		});
+
+		assert!(changed, "expected the second message's secret to be masked");
+		assert!(masked_any);
+
+		// The tool_result-only message must be untouched: still an Array of Unknown,
+		// never collapsed to Text(""), and its JSON payload byte-identical.
+		match &req.messages[0].content {
+			Some(ContentBlock::Array(parts)) => {
+				assert_eq!(parts.len(), 1);
+				match &parts[0] {
+					ContentPart::Unknown(v) => {
+						assert_eq!(v["type"], "tool_result");
+						assert_eq!(v["tool_use_id"], "toolu_01abc");
+						assert_eq!(v["content"], "some tool output, unrelated to any secret");
+					},
+					other => panic!("expected Unknown content part, got {other:?}"),
+				}
+			},
+			other => panic!(
+				"tool_result-only message must remain a structured Array, got {other:?}"
+			),
+		}
+
+		// The second message's secret was masked in place.
+		match &req.messages[1].content {
+			Some(ContentBlock::Text(t)) => assert_eq!(t, "<masked>"),
+			other => panic!("expected masked Text content, got {other:?}"),
+		}
+	}
+
+	/// A message with mixed text + non-text array parts masks only the text parts.
+	#[test]
+	fn mask_preserves_non_text_parts_in_mixed_array() {
+		let mut req = Request {
+			messages: vec![RequestMessage {
+				role: "user".to_string(),
+				content: Some(ContentBlock::Array(vec![
+					ContentPart::Text {
+						r#type: "text".to_string(),
+						text: "leaked: sk-ant-abcdefghijklmnopqrstuvwxyz0123456789".to_string(),
+						rest: Default::default(),
+					},
+					ContentPart::Unknown(serde_json::json!({
+						"type": "image",
+						"source": {"type": "base64", "media_type": "image/png", "data": "AAAA"},
+					})),
+				])),
+				rest: Default::default(),
+			}],
+			..Default::default()
+		};
+
+		let changed = req.mask_text_content(&mut |text: &str| {
+			text.contains("sk-ant-").then(|| "<masked>".to_string())
