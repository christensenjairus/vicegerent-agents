+			}
+		}
+		changed
+	}
 }

 impl super::RequestType for Request {
@@ -344,6 +357,37 @@ impl super::RequestType for Request {
 	fn set_messages(&mut self, messages: Vec<SimpleChatCompletionMessage>) {
 		self.messages = messages.into_iter().map(convert_message).collect();
 	}
+
+	fn mask_text_content(&mut self, mask: &mut dyn FnMut(&str) -> Option<String>) -> bool {
+		let mut changed = false;
+		for msg in self.messages.iter_mut() {
+			let Some(content) = msg.content.as_mut() else {
+				continue;
+			};
+			match content {
+				Content::Text(t) => {
+					if let Some(replacement) = mask(t) {
+						*t = replacement;
+						changed = true;
+					}
+				},
+				// Array parts without a `text` field (image_url, input_audio, etc.) are
+				// left untouched -- only ContentPart::text spans are masked in place, so a
+				// message made entirely of non-text parts never gets rewritten or dropped.
+				Content::Array(parts) => {
+					for part in parts.iter_mut() {
+						if let Some(text) = part.text.as_mut()
+							&& let Some(replacement) = mask(text)
+						{
+							*text = replacement;
+							changed = true;
+						}
+					}
+				},
+			}
+		}
+		changed
+	}
 }

