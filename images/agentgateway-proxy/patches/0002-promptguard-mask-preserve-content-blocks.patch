+	// TextRequest wraps a single plain string with no array/tool_result structure to
+	// preserve, so masking it in place is trivially lossless (unlike the flattening
+	// hazard mask_text_content exists to avoid for the structured formats).
+	fn mask_text_content(&mut self, mask: &mut dyn FnMut(&str) -> Option<String>) -> bool {
+		if let Some(replacement) = mask(&self.content) {
+			self.content = replacement;
+			true
+		} else {
+			false
+		}
+	}
