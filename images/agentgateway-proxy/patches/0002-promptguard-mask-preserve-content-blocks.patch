+/// End-to-end regression test for the request-phase corruption this patch fixes:
+/// `Policy::apply_regex` with `action: Mask` must not corrupt a message whose content is
+/// entirely `tool_result` blocks, even when a *different* message in the same request
+/// matches the mask pattern. Before this patch, `apply_regex` round-tripped every
+/// message through `get_messages()`/`set_messages()`, which flattened the tool_result
+/// message to an empty string and then wrote that empty string back as its entire
+/// content -- corrupting the request and causing Anthropic's API to reject it with
+/// "messages.N: user messages must have non-empty content".
+#[test]
+fn apply_regex_mask_preserves_tool_result_only_message() {
+	use crate::llm::types::messages::{ContentBlock, ContentPart, Request, RequestMessage};
+
+	let mut req = Request {
+		messages: vec![
+			RequestMessage {
+				role: "user".to_string(),
+				content: Some(ContentBlock::Array(vec![ContentPart::Unknown(
+					serde_json::json!({
+						"type": "tool_result",
+						"tool_use_id": "toolu_01abc",
+						"content": "unrelated tool output",
+					}),
+				)])),
+				rest: Default::default(),
+			},
+			RequestMessage {
+				role: "user".to_string(),
+				content: Some(ContentBlock::Text(
+					"here is a secret: 4111111111111111".to_string(),
+				)),
+				rest: Default::default(),
+			},
+		],
+		..Default::default()
+	};
+
+	let rgx = RegexRules {
+		action: Action::Mask,
+		rules: vec![RegexRule::Regex {
+			pattern: regex::Regex::new(r"\d{16}").unwrap(),
+		}],
+	};
+	let rej = RequestRejection::default();
+
+	let outcome = Policy::apply_regex(&mut req, &rgx, &rej).expect("apply_regex should succeed");
+	assert!(
+		matches!(outcome, GuardrailOutcome::Masked),
+		"expected Masked outcome"
+	);
+
+	// The tool_result-only message must survive completely untouched.
+	match &req.messages[0].content {
+		Some(ContentBlock::Array(parts)) => match &parts[0] {
+			ContentPart::Unknown(v) => {
+				assert_eq!(v["type"], "tool_result");
+				assert_eq!(v["content"], "unrelated tool output");
+			},
+			other => panic!("expected untouched tool_result block, got {other:?}"),
+		},
+		other => panic!(
+			"tool_result-only message must remain a non-empty structured Array, got {other:?}"
+		),
+	}
+
+	// The credit-card-shaped digit run in the second message was masked.
+	match &req.messages[1].content {
+		Some(ContentBlock::Text(t)) => assert!(
+			!t.contains("4111111111111111"),
+			"expected digits to be masked, got: {t}"
+		),
+		other => panic!("expected masked Text content, got {other:?}"),
+	}
+}
+
+/// Companion test: with `action: Reject`, a match must still reject the whole request
+/// (unchanged behavior) and must not touch req.messages at all.
+#[test]
+fn apply_regex_reject_still_rejects_and_does_not_mutate() {
+	use crate::llm::types::messages::{ContentBlock, Request, RequestMessage};
+
+	let mut req = Request {
+		messages: vec![RequestMessage {
+			role: "user".to_string(),
+			content: Some(ContentBlock::Text(
+				"here is a secret: 4111111111111111".to_string(),
+			)),
+			rest: Default::default(),
+		}],
+		..Default::default()
+	};
+
+	let rgx = RegexRules {
+		action: Action::Reject,
+		rules: vec![RegexRule::Regex {
+			pattern: regex::Regex::new(r"\d{16}").unwrap(),
+		}],
+	};
+	let rej = RequestRejection::default();
+
+	let outcome = Policy::apply_regex(&mut req, &rgx, &rej).expect("apply_regex should succeed");
+	assert!(
+		matches!(outcome, GuardrailOutcome::Rejected(_)),
+		"expected Rejected outcome"
+	);
+
+	// Reject must never mutate the request.
+	match &req.messages[0].content {
+		Some(ContentBlock::Text(t)) => assert_eq!(t, "here is a secret: 4111111111111111"),
+		other => panic!("Reject path must not mutate content, got {other:?}"),
+	}
+}
