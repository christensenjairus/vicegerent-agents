diff --git a/crates/agentgateway/src/llm/types/messages.rs b/crates/agentgateway/src/llm/types/messages.rs
index 323e5ee..377702c 100644
--- a/crates/agentgateway/src/llm/types/messages.rs
+++ b/crates/agentgateway/src/llm/types/messages.rs
@@ -251,6 +251,65 @@ impl RequestType for Request {
 		self.messages = message_prompts.into_iter().map(Into::into).collect();
 	}

+	fn mask_text_content(&mut self, mask: &mut dyn FnMut(&str) -> Option<String>) -> bool {
+		let mut changed = false;
+
+		// System prompt: mask each text span, whether it's the plain-string form or an
+		// array of text parts. Never touches non-text parts (there currently are none in
+		// TextBlock, but this keeps the match exhaustive-safe if that changes).
+		if let Some(system) = &mut self.system {
+			match system {
+				TextBlock::Text(t) => {
+					if let Some(replacement) = mask(t) {
+						*t = replacement;
+						changed = true;
+					}
+				},
+				TextBlock::Array(parts) => {
+					for part in parts.iter_mut() {
+						if let TextPart::Text { text, .. } = part
+							&& let Some(replacement) = mask(text)
+						{
+							*text = replacement;
+							changed = true;
+						}
+					}
+				},
+			}
+		}
+
+		// Messages: mask only ContentBlock::Text and ContentPart::Text spans. A message
+		// whose content is ContentBlock::Array of entirely non-text parts (e.g. a
+		// tool_result-only user turn) is walked and left completely untouched -- unlike
+		// get_messages()/set_messages(), it is never flattened, never round-tripped, and
+		// never has its structure replaced.
+		for msg in self.messages.iter_mut() {
+			let Some(content) = msg.content.as_mut() else {
+				continue;
+			};
+			match content {
+				ContentBlock::Text(t) => {
+					if let Some(replacement) = mask(t) {
+						*t = replacement;
+						changed = true;
+					}
+				},
+				ContentBlock::Array(parts) => {
+					for part in parts.iter_mut() {
+						if let ContentPart::Text { text, .. } = part
+							&& let Some(replacement) = mask(text)
+						{
+							*text = replacement;
+							changed = true;
+						}
+					}
+				},
+			}
+		}
+
+		changed
+	}
+
 	fn to_openai(&self) -> Result<Vec<u8>, AIError> {
 		conversion::completions::from_messages::translate(self)
 	}
@@ -421,6 +480,19 @@ impl ResponseType for Response {
 	fn serialize(&self) -> serde_json::Result<Vec<u8>> {
 		serde_json::to_vec(&self)
