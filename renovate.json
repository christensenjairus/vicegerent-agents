{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranchPatterns": ["main"],
  "enabledManagers": [
    "custom.regex",
    "dockerfile",
    "flux",
    "helm-values",
    "kubernetes",
    "kustomize",
    "npm",
    "pip_requirements",
    "pre-commit"
  ],
  "labels": ["renovate"],
  "dependencyDashboard": true,
  "configMigration": true,
  "recreateWhen": "always",
  "rollbackPrs": false,
  "prConcurrentLimit": 5,
  "flux": {
    "managerFilePatterns": [
      "/^clusters/.+\\.ya?ml$/",
      "/^infrastructure/controllers/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/^infrastructure/controllers/.+/values\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/^(apps|clusters|infrastructure)/.+\\.ya?ml$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/^(apps|clusters|infrastructure)/.*/kustomization\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks"
    },
    {
      "matchFileNames": ["infrastructure/controllers/**"],
      "groupName": "infrastructure controller ({{packageFileDir}})"
    },
    {
      "matchFileNames": [".gitlab-ci.yml"],
      "groupName": "gitlab ci images"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/agentgateway/controller",
        "cr.agentgateway.dev/charts/agentgateway-crds",
        "cr.agentgateway.dev/charts/agentgateway"
      ],
      "allowedVersions": "<2.0.0"
    },
    {
      "description": "Flux controllers are upgraded as a matched set via `flux bootstrap` regeneration, never per-image. The flux manager still surfaces a single grouped flux-version signal from the gotk-components header.",
      "matchFileNames": ["clusters/**/flux-system/gotk-components.yaml"],
      "matchManagers": ["kubernetes", "kustomize"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^infrastructure/controllers/agent-sandbox/chart/repository\\.ya?ml$/"
      ],
      "matchStrings": [
        "url:\\s*https://github\\.com/(?<depName>[^\\s]+?)\\.git\\s+ref:\\s+tag:\\s*(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^infrastructure/controllers/agentgateway/chart/values\\.ya?ml$/",
        "/^apps/vicegerent/gateway/gateway\\.ya?ml$/"
      ],
      "matchStrings": [
        "registry:\\s*(?<registryOrg>[^\\s]+)\\s*\\n\\s+repository:\\s*(?<depName>[^\\s]+)\\s*\\n\\s+tag:\\s*(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "{{registryOrg}}/{{depName}}",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^apps/vicegerent/agents/.+/sandbox\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s*(?<depName>[^:\\s]+/[^:\\s]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^images/.+/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\s+ARG \\w+_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.gitlab-ci\\.yml$/"
      ],
      "matchStrings": [
        "harbor\\.hahomelabs\\.com/(?<depName>[a-zA-Z0-9][^:@\\s]*[a-zA-Z0-9])[:@](?<currentValue>[a-zA-Z0-9][^\\s,\\]\\[\\\\\"']*[a-zA-Z0-9])"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^apps/vicegerent/mcps/.+/server\\.ya?ml$/"
      ],
      "matchStrings": [
        "args:\\s*\\[\\s*-y\\s*,\\s*'?(?<depName>[^@'\\s\\]]+)@(?<currentValue>[^'\\s\\]]+)'?\\s*\\]"
      ],
      "datasourceTemplate": "npm"
    }
  ]
}
