#!/usr/bin/env bash
# scripts/host/setup-host-mcp
#
# Idempotent setup of the host-side prerequisites for the vicegerent host stack
# (ToolHive workloads + vMCP + ghostunnel + rclone, kept awake by caffeinate):
#
#   1. Homebrew packages: thv (ToolHive), ghostunnel, supervisor, rclone
#   2. Python venv + deps: pip install -r host/mcp/requirements-host.txt
#   3. ToolHive secrets provider + required API-key secrets (guidance)
#   4. Final doctor check: vicegerent-mcp doctor
#
# Flags:
#   -y, --yes      auto-approve every step (non-interactive)
#   -h, --help     show this help
#
# Prerequisites on the host Mac: Homebrew, a running kind cluster (for the
# kubernetes MCP server) — see `./vicegerent cluster setup`.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

ASSUME_YES=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -y|--yes)    ASSUME_YES=1 ;;
    -h|--help)   sed -n '2,17p' "$0"; exit 0 ;;
    *) echo "unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

if [[ -t 1 ]]; then
  B=$'\033[1m'; G=$'\033[0;32m'; Y=$'\033[0;33m'; R=$'\033[0;31m'; N=$'\033[0m'
else
  B=""; G=""; Y=""; R=""; N=""
fi
info()    { echo "${G}✓${N} $*"; }
step()    { echo; echo "${B}== $* ==${N}"; }
warn()    { echo "${Y}!${N} $*" >&2; }
die()     { echo "${R}ERROR:${N} $*" >&2; exit 1; }

confirm() {
  if [[ "$ASSUME_YES" == "1" ]]; then return 0; fi
  local ans
  read -r -p "  Proceed? [y/N] " ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required but not found — install Homebrew first"
}

# ---------------------------------------------------------------------------
# 0. Sanity
# ---------------------------------------------------------------------------
need_cmd brew
need_cmd python3

# ---------------------------------------------------------------------------
# 1. Homebrew packages
# ---------------------------------------------------------------------------
step "Homebrew packages"

# ToolHive ships from the stacklok tap; ghostunnel + supervisor are core formulae.
# `bin:formula` pairs — plain indexed array so this works on macOS's stock bash 3.2
# (which has no associative arrays; `declare -A [thv]=…` there dies under `set -u`).
BREW_FORMULAE=(
  "thv:stacklok/tap/thv"
  "ghostunnel:ghostunnel"
  "supervisor:supervisor"
  "rclone:rclone"
)
MISSING=()
for entry in "${BREW_FORMULAE[@]}"; do
  formula="${entry#*:}"
  if brew list --formula "$formula" >/dev/null 2>&1; then
    info "$formula already installed"
  else
    MISSING+=("$formula")
  fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo "  Will install: ${MISSING[*]}"
  if confirm; then
    brew install "${MISSING[@]}"
    info "Installed: ${MISSING[*]}"
  else
    warn "Skipped Homebrew install. Install manually, e.g.:"
    warn "    brew install ${MISSING[*]}"
  fi
fi

command -v thv >/dev/null 2>&1 || warn "thv still not on PATH — see https://github.com/stacklok/toolhive"

# ---------------------------------------------------------------------------
# 2. Python deps
# ---------------------------------------------------------------------------
step "Python venv + dependencies"

REQ="$REPO_ROOT/host/mcp/requirements-host.txt"
VENV="$REPO_ROOT/host/mcp/.venv"
[[ -f "$REQ" ]] || die "requirements-host.txt not found: $REQ"

if [[ ! -d "$VENV" ]]; then
  echo "  Creating venv at host/mcp/.venv"
  python3 -m venv "$VENV"
fi

if "$VENV/bin/python" -c "
import importlib.util, sys
mods = ['rich', 'supervisor', 'textual']
missing = [m for m in mods if importlib.util.find_spec(m) is None]
if missing:
    print('missing:', ' '.join(missing))
    sys.exit(1)
" 2>/dev/null; then
  info "Python dependencies up to date (host/mcp/.venv)"
else
  echo "  Installing from $REQ into host/mcp/.venv"
  confirm || die "Aborted."
  "$VENV/bin/pip" install -r "$REQ" -q
  info "Python dependencies installed into host/mcp/.venv"
fi

# ---------------------------------------------------------------------------
# 3. ToolHive secrets provider + required secrets
# ---------------------------------------------------------------------------
step "ToolHive secrets"

if command -v thv >/dev/null 2>&1 && thv secret list >/dev/null 2>&1; then
  info "thv secrets provider configured"
else
  warn "No thv secrets provider configured. OAuth tokens (notion/linear) won't"
  warn "persist and API-key secrets can't be stored. Configure one (choose 'encrypted'):"
  echo "     thv secret setup"
fi

echo
echo "  MCP servers are OFF by default. Enable the ones you want and set their API"
echo "  keys interactively with:"
echo "     ./vicegerent mcp configure"
echo "  (GitLab/Tavily/Firecrawl prompt for a key; Notion/Linear use OAuth — a browser"
echo "  tab opens on first start and the token persists via the secrets provider.)"

# ---------------------------------------------------------------------------
# 4. Doctor check
# ---------------------------------------------------------------------------
step "Doctor check"
echo
"$REPO_ROOT/host/mcp/.venv/bin/python" "$REPO_ROOT/host/mcp/vicegerent_mcp.py" doctor || true

echo
echo "${G}${B}Host stack setup complete.${N}"
echo
echo "Next steps:"
echo "  1. Provision host + cluster secrets:  ./vicegerent secrets setup platform"
echo "     (writes host ghostunnel material to ~/.vicegerent/ghostunnel)"
echo "  2. Ensure the kind cluster is up:      ./vicegerent cluster setup"
echo "  3. Enable + set up the MCP servers:    ./vicegerent mcp configure"
echo "  4. Bring up the stack:                 ./vicegerent start"
