#!/usr/bin/env bash
# scripts/host/setup-host-mcp
#
# Idempotent setup of all host-side prerequisites for vicegerent host MCP:
#
#   1. Homebrew packages: caddy ghostunnel node supervisor
#   2. Python deps: pip install -r host/mcp/requirements-host.txt
#   3. mcp-proxy-server: npm ci + npm run build (vendored at host/mcp-proxy-server/)
#   4. k8s-mcp-server: build the in-repo Go binary (host/k8s-mcp-server/k8s-mcp-server)
#   5. Final doctor check: vicegerent-mcp doctor
#
# Flags:
#   -y, --yes      auto-approve every step (non-interactive)
#   --rebuild      force npm ci + rebuild of mcp-proxy-server
#   -h, --help     show this help
#
# Prerequisites on the host Mac: Homebrew, Go (for k8s-mcp-server)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
PROXY_DIR="$REPO_ROOT/host/mcp-proxy-server"

ASSUME_YES=0
UPDATE_PROXY=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -y|--yes)    ASSUME_YES=1 ;;
    --rebuild)   UPDATE_PROXY=1 ;;
    -h|--help)   sed -n '2,18p' "$0"; exit 0 ;;
    *) echo "unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

if [[ -t 1 ]]; then
  B=$'\033[1m'; G=$'\033[0;32m'; Y=$'\033[0;33m'; R=$'\033[0;31m'; N=$'\033[0m'
else
  B=""; G=""; Y=""; R=""; N=""
fi
info()    { echo "${G}✓${N} $*"; }
step()    { echo; echo "${B}== $* ==${N}"; }
warn()    { echo "${Y}!${N} $*" >&2; }
die()     { echo "${R}ERROR:${N} $*" >&2; exit 1; }
skipped() { echo "  (already present — skipping)"; }

confirm() {
  if [[ "$ASSUME_YES" == "1" ]]; then return 0; fi
  local ans
  read -r -p "  Proceed? [y/N] " ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required but not found — install Homebrew first"
}

# ---------------------------------------------------------------------------
# 0. Sanity
# ---------------------------------------------------------------------------
need_cmd brew
need_cmd python3

# ---------------------------------------------------------------------------
# 1. Homebrew packages
# ---------------------------------------------------------------------------
step "Homebrew packages"

BREW_PACKAGES=(caddy ghostunnel node supervisor)
MISSING=()
for pkg in "${BREW_PACKAGES[@]}"; do
  if brew list --formula "$pkg" >/dev/null 2>&1; then
    info "$pkg already installed"
  else
    MISSING+=("$pkg")
  fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo "  Will install: ${MISSING[*]}"
  confirm "Install missing Homebrew packages?" || die "Aborted."
  brew install "${MISSING[@]}"
  info "Installed: ${MISSING[*]}"
fi

# ---------------------------------------------------------------------------
# 2. Python deps
# ---------------------------------------------------------------------------
step "Python venv + dependencies"

REQ="$REPO_ROOT/host/mcp/requirements-host.txt"
VENV="$REPO_ROOT/host/mcp/.venv"
[[ -f "$REQ" ]] || die "requirements-host.txt not found: $REQ"

if [[ ! -d "$VENV" ]]; then
  echo "  Creating venv at host/mcp/.venv"
  python3 -m venv "$VENV"
fi

# Check if all deps are already satisfied inside the venv
if "$VENV/bin/python" -c "
import importlib, sys
pkgs = {'rich': 'rich', 'textual': 'textual'}
missing = [name for name, mod in pkgs.items() if importlib.util.find_spec(mod) is None]
if missing:
    print('missing:', ' '.join(missing))
    sys.exit(1)
" 2>/dev/null; then
  info "Python dependencies up to date (host/mcp/.venv)"
else
  echo "  Installing from $REQ into host/mcp/.venv"
  confirm "pip install -r host/mcp/requirements-host.txt into venv?" || die "Aborted."
  "$VENV/bin/pip" install -r "$REQ" -q
  info "Python dependencies installed into host/mcp/.venv"
fi

# ---------------------------------------------------------------------------
# 3. mcp-proxy-server
# ---------------------------------------------------------------------------
step "mcp-proxy-server (host/mcp-proxy-server/)"

[[ -d "$PROXY_DIR" ]] || die "mcp-proxy-server source not found at $PROXY_DIR — check your repo clone"

if [[ "$UPDATE_PROXY" == "1" ]]; then
  echo "  Rebuilding mcp-proxy-server..."
  confirm "npm ci + npm run build in $PROXY_DIR?" || die "Aborted."
  npm --prefix "$PROXY_DIR" ci --quiet
  npm --prefix "$PROXY_DIR" run build --silent
  info "mcp-proxy-server rebuilt"
elif [[ -f "$PROXY_DIR/build/sse.js" ]]; then
  info "mcp-proxy-server already built (host/mcp-proxy-server/build/)"
  echo "  (Run with --rebuild to force a clean rebuild)"
else
  echo "  Building mcp-proxy-server for the first time..."
  confirm "npm ci + npm run build in host/mcp-proxy-server/?" || die "Aborted."
  npm --prefix "$PROXY_DIR" ci --quiet
  npm --prefix "$PROXY_DIR" run build --silent
  info "mcp-proxy-server built"
fi

# ---------------------------------------------------------------------------
# 4. Doctor check
# ---------------------------------------------------------------------------
step "Doctor check"
echo
"$REPO_ROOT/host/mcp/.venv/bin/python" "$REPO_ROOT/host/mcp/vicegerent_mcp.py" doctor || true

echo
echo "${G}${B}Host MCP setup complete.${N}"
echo
echo "Next steps:"
echo "  1. Sign in to 1Password:  op signin"
echo "  2. Start the stack:       ./vicegerent-mcp start --proxy-dir $PROXY_DIR"
echo "  3. Open the TUI:          ./vicegerent-mcp tui"
