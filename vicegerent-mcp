#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
venv_python="$repo_root/host/mcp/.venv/bin/python"
if [[ -x "$venv_python" ]]; then
  exec "$venv_python" "$repo_root/host/mcp/vicegerent_mcp.py" "$@"
else
  echo "ERROR: venv not found. Run: ./vicegerent mcp setup" >&2
  exit 1
fi
