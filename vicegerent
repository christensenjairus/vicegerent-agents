#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -t 1 ]]; then
  B=$'\033[1m'; C=$'\033[0;36m'; N=$'\033[0m'
else
  B=""; C=""; N=""
fi

usage() {
  cat <<EOF
${B}vicegerent${N} — operational CLI for the vicegerent infra-agent platform

${B}Usage:${N}
  ${C}vicegerent cluster setup${N}           create the minikube cluster
  ${C}vicegerent cluster pause${N}           pause the minikube cluster
  ${C}vicegerent cluster resume${N}          resume the minikube cluster
  ${C}vicegerent cluster status${N}          show minikube cluster status
  ${C}vicegerent secrets setup${N}           run secrets setup (idempotent)
  ${C}vicegerent bootstrap${N}               bootstrap Flux against this repo
  ${C}vicegerent agent dashboard <name>${N}  open an agent dashboard in browser
  ${C}vicegerent agent creds <name>${N}      show agent dashboard credentials and URL
  ${C}vicegerent test gateway${N}            run MCP gateway tests
  ${C}vicegerent test policies${N}           run MCP policy enforcement tests
  ${C}vicegerent mcp setup${N}               set up host-side MCP prerequisites
  ${C}vicegerent slack manifest${N}          generate a Slack app manifest for a named bot
EOF
}

cluster_usage() {
  cat <<EOF
${B}vicegerent cluster${N} — minikube cluster lifecycle

  ${C}setup${N}    create the cluster (overridable env: CPUS MEMORY DISK_SIZE DRIVER NETWORK CONTAINER_RUNTIME CNI ADDONS PROFILE)
  ${C}pause${N}    minikube pause --profile vicegerent
  ${C}resume${N}   minikube unpause --profile vicegerent
  ${C}status${N}   minikube status --profile vicegerent
EOF
}

cluster_setup() {
  local cpus="${CPUS:-4}"
  local memory="${MEMORY:-16384}"
  local disk_size="${DISK_SIZE:-50g}"
  local driver="${DRIVER:-vfkit}"
  local network="${NETWORK:-socket_vmnet}"
  local container_runtime="${CONTAINER_RUNTIME:-containerd}"
  local cni="${CNI:-cilium}"
  local addons="${ADDONS:-gvisor,metrics-server}"
  local profile="${PROFILE:-vicegerent}"

  local cmd=(
    minikube start
    --profile "$profile"
    --driver "$driver"
    --network "$network"
    --container-runtime "$container_runtime"
    --cni="$cni"
    --addons "$addons"
    --cpus "$cpus"
    --memory "$memory"
    --disk-size "$disk_size"
  )

  echo "${B}Running:${N} ${cmd[*]} $*"
  exec "${cmd[@]}" "$@"
}

# Port-forward agentgateway, check vicegerent-mcp is running, run a test script,
# then tear everything down. Used by `test gateway` and `test policies`.
run_with_portforward() {
  local script="$1"; shift

  # Check vicegerent-mcp is running
  if ! "$REPO_ROOT/vicegerent-mcp" status >/dev/null 2>&1; then
    echo "ERROR: vicegerent-mcp is not running. Start it first: ./vicegerent-mcp start" >&2
    exit 1
  fi

  # Port-forward agentgateway
  local pf_pid
  kubectl --context vicegerent -n agentgateway-system \
    port-forward svc/agentgateway-proxy 8080:80 >/dev/null 2>&1 &
  pf_pid=$!
  trap 'kill "$pf_pid" 2>/dev/null || true' EXIT INT TERM

  # Wait for port to open (max 15s)
  local i=0
  while ! python3 -c "import socket; s=socket.create_connection(('127.0.0.1',8080),0.25); s.close()" 2>/dev/null; do
    ((i++))
    if [[ $i -ge 60 ]]; then
      echo "ERROR: agentgateway port-forward did not become ready after 15s" >&2
      kill "$pf_pid" 2>/dev/null || true
      exit 1
    fi
    sleep 0.25
  done

  export GATEWAY_URL="http://localhost:8080"
  "$script" "$@"
  local rc=$?
  kill "$pf_pid" 2>/dev/null || true
  trap - EXIT INT TERM
  return $rc
}

case "${1:-}" in
  cluster)
    shift
    case "${1:-}" in
      setup)
        shift
        [[ "${1:-}" == "--help" ]] && { cluster_usage; exit 0; }
        cluster_setup "$@"
        ;;
      pause)
        shift
        [[ "${1:-}" == "--help" ]] && { echo "minikube pause --profile vicegerent"; exit 0; }
        exec minikube pause --profile vicegerent "$@"
        ;;
      resume)
        shift
        [[ "${1:-}" == "--help" ]] && { echo "minikube unpause --profile vicegerent"; exit 0; }
        exec minikube unpause --profile vicegerent "$@"
        ;;
      status)
        shift
        [[ "${1:-}" == "--help" ]] && { echo "minikube status --profile vicegerent"; exit 0; }
        exec minikube status --profile vicegerent "$@"
        ;;
      --help|-h|"")
        cluster_usage
        exit 0
        ;;
      *)
        echo "unknown cluster subcommand: $1" >&2
        cluster_usage >&2
        exit 1
        ;;
    esac
    ;;
  secrets)
    shift
    case "${1:-}" in
      setup)
        shift
        exec "$REPO_ROOT/scripts/install/setup-secrets.sh" "$@"
        ;;
      --help|-h|"")
        echo "vicegerent secrets setup  →  scripts/install/setup-secrets.sh"
        exit 0
        ;;
      *)
        echo "unknown secrets subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  bootstrap)
    shift
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      echo "vicegerent bootstrap — bootstrap Flux against this repo"
      echo "  Idempotent. Flags: -y/--yes, --reseed-secrets."
      echo "  Env: KUBE_CONTEXT REPO_URL BRANCH CLUSTER_PATH PRIVATE_KEY_FILE"
      exit 0
    fi
    exec "$REPO_ROOT/scripts/install/install.sh" "$@"
    ;;
  agent)
    shift
    case "${1:-}" in
      dashboard)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent agent dashboard <agent-name> — open the agent dashboard in browser"
          exit 0
        fi
        [[ $# -ge 1 ]] || { echo "usage: vicegerent agent dashboard <agent-name>" >&2; exit 2; }
        AGENT="$1"
        NAMESPACE="${HERMES_DASHBOARD_NAMESPACE:-agent-sandbox}"
        CONTEXT_ARG=()
        kubectl config get-contexts vicegerent >/dev/null 2>&1 && CONTEXT_ARG=(--context vicegerent)
        PROFILE="${MINIKUBE_PROFILE:-vicegerent}"
        SERVICE="${AGENT}-dashboard"
        node_port="$(kubectl "${CONTEXT_ARG[@]}" -n "$NAMESPACE" get svc "$SERVICE" \
          -o jsonpath='{.spec.ports[?(@.name=="dashboard")].nodePort}' 2>/dev/null || true)"
        [[ -n "$node_port" ]] || node_port="$(kubectl "${CONTEXT_ARG[@]}" -n "$NAMESPACE" get svc "$SERVICE" \
          -o jsonpath='{.spec.ports[0].nodePort}' 2>/dev/null || true)"
        node_ip="$(minikube -p "$PROFILE" ip 2>/dev/null || true)"
        [[ -n "$node_ip" ]] || node_ip="$(kubectl "${CONTEXT_ARG[@]}" get nodes \
          -o jsonpath='{.items[0].status.addresses[?(@.type=="InternalIP")].address}' 2>/dev/null || true)"
        if [[ -n "$node_ip" && -n "$node_port" ]]; then
          echo "Dashboard URL: http://${node_ip}:${node_port}/"
        fi
        exec "$REPO_ROOT/scripts/dashboard/open-dashboard.sh" "$@"
        ;;
      creds)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent agent creds <agent-name> — print credentials and dashboard URL"
          exit 0
        fi
        [[ $# -ge 1 ]] || { echo "usage: vicegerent agent creds <agent-name>" >&2; exit 2; }
        AGENT="$1"
        NAMESPACE="${HERMES_DASHBOARD_NAMESPACE:-agent-sandbox}"
        CONTEXT_ARG=()
        kubectl config get-contexts vicegerent >/dev/null 2>&1 && CONTEXT_ARG=(--context vicegerent)
        PROFILE="${MINIKUBE_PROFILE:-vicegerent}"
        SERVICE="${AGENT}-dashboard"
        "$REPO_ROOT/scripts/dashboard/dashboard-basic-cred.sh" "$@"
        node_port="$(kubectl "${CONTEXT_ARG[@]}" -n "$NAMESPACE" get svc "$SERVICE" \
          -o jsonpath='{.spec.ports[?(@.name=="dashboard")].nodePort}' 2>/dev/null || true)"
        [[ -n "$node_port" ]] || node_port="$(kubectl "${CONTEXT_ARG[@]}" -n "$NAMESPACE" get svc "$SERVICE" \
          -o jsonpath='{.spec.ports[0].nodePort}' 2>/dev/null || true)"
        node_ip="$(minikube -p "$PROFILE" ip 2>/dev/null || true)"
        [[ -n "$node_ip" ]] || node_ip="$(kubectl "${CONTEXT_ARG[@]}" get nodes \
          -o jsonpath='{.items[0].status.addresses[?(@.type=="InternalIP")].address}' 2>/dev/null || true)"
        if [[ -n "$node_ip" && -n "$node_port" ]]; then
          echo "url:      http://${node_ip}:${node_port}/"
        fi
        ;;
      --help|-h|"")
        echo "vicegerent agent dashboard <name>  →  open agent dashboard"
        echo "vicegerent agent creds <name>      →  show credentials and URL"
        exit 0
        ;;
      *)
        echo "unknown agent subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  test)
    shift
    case "${1:-}" in
      gateway)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent test gateway — probe MCP endpoints (auto port-forwards agentgateway, requires vicegerent-mcp running)"
          exit 0
        fi
        run_with_portforward "$REPO_ROOT/scripts/test-mcp-gateway.sh" "$@"
        ;;
      policies)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent test policies — run MCP policy enforcement tests (auto port-forwards agentgateway, requires vicegerent-mcp running)"
          exit 0
        fi
        run_with_portforward "$REPO_ROOT/scripts/test-mcp-policies.sh" "$@"
        ;;
      --help|-h|"")
        echo "vicegerent test gateway   →  scripts/test-mcp-gateway.sh"
        echo "vicegerent test policies  →  scripts/test-mcp-policies.sh"
        exit 0
        ;;
      *)
        echo "unknown test subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  mcp)
    shift
    case "${1:-}" in
      setup)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent mcp setup — set up all host-side MCP prerequisites"
          echo "  Installs Homebrew packages, Python venv, mcp-proxy-server, k8s-mcp-server."
          echo "  Flags: -y/--yes, --rebuild"
          exit 0
        fi
        exec "$REPO_ROOT/scripts/host/setup-host-mcp" "$@"
        ;;
      --help|-h|"")
        echo "vicegerent mcp setup  →  scripts/host/setup-host-mcp"
        exit 0
        ;;
      *)
        echo "unknown mcp subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  slack)
    shift
    case "${1:-}" in
      manifest)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent slack manifest — generate a Hermes Slack app manifest for a named bot"
          echo "  Usage: vicegerent slack manifest <name> [output-file]"
          echo "  Example: vicegerent slack manifest \"Hermes Infra\" infra-manifest.yaml"
          exit 0
        fi
        exec "$REPO_ROOT/scripts/slack/generate-manifest.sh" "$@"
        ;;
      --help|-h|"")
        echo "vicegerent slack manifest  →  scripts/slack/generate-manifest.sh"
        exit 0
        ;;
      *)
        echo "unknown slack subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  help|--help|-h|"")
    usage
    exit 0
    ;;
  *)
    echo "unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
