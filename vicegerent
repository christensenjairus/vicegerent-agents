#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -t 1 ]]; then
  B=$'\033[1m'; C=$'\033[0;36m'; N=$'\033[0m'
else
  B=""; C=""; N=""
fi

# Guard against a bare (context-less) kubectl/cilium call silently hitting whatever
# cluster the ambient kubeconfig happens to point at.
require_kube_context() {
  local want="$1" have
  have="$(kubectl config current-context 2>/dev/null || true)"
  [[ "$have" == "$want" ]] || {
    echo "ERROR: current kubectl context is '${have:-<none>}', expected '$want'. Run: kubectl config use-context $want" >&2
    exit 1
  }
}

usage() {
  cat <<EOF
${B}vicegerent${N} — operational CLI for the vicegerent infra-agent platform

${B}Usage:${N}
  ${C}vicegerent start${N}                   start the Kind cluster + host ToolHive/vMCP stack
  ${C}vicegerent stop${N}                    stop the host stack + Kind cluster
  ${C}vicegerent cluster setup${N}           create the Kind cluster (+ Cilium CNI)
  ${C}vicegerent cluster pause${N}           stop the Kind node container
  ${C}vicegerent cluster resume${N}          start the Kind node container
  ${C}vicegerent cluster status${N}          show Kind cluster nodes
  ${C}vicegerent secrets setup platform${N}       provision platform-wide secrets (idempotent)
  ${C}vicegerent secrets setup agent <name>${N}    provision a named agent's secrets (idempotent)
  ${C}vicegerent bootstrap${N}               bootstrap Flux against this repo
  ${C}vicegerent agent dashboard <name>${N}  open an agent dashboard in browser
  ${C}vicegerent agent creds <name>${N}      show agent dashboard credentials and URL
  ${C}vicegerent test gateway${N}            run MCP gateway tests
  ${C}vicegerent test policies${N}           run MCP policy enforcement tests
  ${C}vicegerent test egress <name>${N}      run egress-proxy redaction/enforcement tests
  ${C}vicegerent mcp setup${N}               set up host-side MCP prerequisites
  ${C}vicegerent mcp configure${N}           enable/skip each MCP server + set secrets
  ${C}vicegerent mcp tui${N}                 open the host stack TUI dashboard
  ${C}vicegerent slack manifest${N}          generate a Slack app manifest for a named bot
EOF
}

cluster_usage() {
  cat <<EOF
${B}vicegerent cluster${N} — Kind cluster lifecycle

  ${C}setup${N}    create the Kind cluster and install Cilium as the CNI
             (overridable env: CLUSTER_NAME KIND_CONFIG CILIUM_VERSION KIND_DOCKER_NETWORK)
  ${C}pause${N}    docker stop ${CLUSTER_NAME:-vicegerent}-control-plane
  ${C}resume${N}   docker start ${CLUSTER_NAME:-vicegerent}-control-plane
  ${C}status${N}   kubectl --context kind-${CLUSTER_NAME:-vicegerent} get nodes
EOF
}

# Patch in-cluster CoreDNS to resolve host.docker.internal: Kind's CoreDNS forwards
# to the pod's own loopback, not Docker's embedded resolver, so pods otherwise can't
# resolve it (that's how agentgateway reaches the host ghostunnel). Pin it to the
# detected host gateway IP. Idempotent — skipped if already present.
patch_coredns() {
  local cluster_name="$1" docker_network="$2"
  local ctx="kind-${cluster_name}"

  local corefile new
  corefile="$(kubectl --context "$ctx" -n kube-system get configmap coredns -o jsonpath='{.data.Corefile}')"

  if grep -q 'host.docker.internal' <<<"$corefile"; then
    echo "${B}CoreDNS already patched (host.docker.internal); skipping.${N}"
    return
  fi

  local host_ip
  host_ip="$(docker run --rm --network "$docker_network" alpine \
    sh -c 'getent hosts host.docker.internal 2>/dev/null | awk "{print \$1; exit}"' 2>/dev/null || true)"
  [[ -n "$host_ip" ]] || host_ip="192.168.65.254"
  echo "${B}CoreDNS: resolve host.docker.internal → ${host_ip}${N}"
  new="$(awk -v ip="$host_ip" '{print} /^\.:53 \{/ && !d {
    print "    hosts {"; print "        " ip " host.docker.internal"; print "        fallthrough"; print "    }"; d=1}' <<<"$corefile")"

  kubectl --context "$ctx" -n kube-system create configmap coredns \
    --from-literal=Corefile="$new" --dry-run=client -o yaml \
    | kubectl --context "$ctx" -n kube-system apply -f -
  kubectl --context "$ctx" -n kube-system rollout restart deployment/coredns
}

# Create the Kind cluster (Kind's default CNI disabled) and install Cilium so it
# owns pod networking — the CiliumNetworkPolicy egress lock is the security model.
cluster_setup() {
  local cluster_name="${CLUSTER_NAME:-vicegerent}"
  local kind_config="${KIND_CONFIG:-$REPO_ROOT/scripts/install/kind-config.yaml}"
  local cilium_version="${CILIUM_VERSION:-1.17.5}"
  # Dedicated docker network so this cluster's node containers are isolated from the
  # default shared `kind` network and any other kind clusters.
  local docker_network="${KIND_DOCKER_NETWORK:-vicegerent}"

  for cmd in kind kubectl docker; do
    command -v "$cmd" >/dev/null 2>&1 || { echo "ERROR: $cmd is not installed or not on PATH" >&2; exit 1; }
  done
  command -v cilium >/dev/null 2>&1 || {
    echo "ERROR: cilium (cilium-cli) is not installed or not on PATH." >&2
    echo "  Install it: brew install cilium-cli" >&2
    echo "  (or see https://docs.cilium.io/en/stable/gettingstarted/k8s-install-helm/)" >&2
    exit 1
  }

  if kind get clusters 2>/dev/null | grep -qx "$cluster_name"; then
    echo "${B}Kind cluster '${cluster_name}' already exists; skipping create.${N}"
  else
    echo "${B}Creating Kind cluster '${cluster_name}' on docker network '${docker_network}'…${N}"
    KIND_EXPERIMENTAL_DOCKER_NETWORK="$docker_network" \
      kind create cluster --name "$cluster_name" --config "$kind_config"
  fi

  require_kube_context "kind-${cluster_name}"

  echo "${B}Installing Cilium ${cilium_version} as the CNI…${N}"
  cilium install --version "$cilium_version" --context "kind-${cluster_name}" 2>/dev/null \
    || echo "${B}Cilium already installed or install skipped; checking status…${N}"
  cilium status --wait --context "kind-${cluster_name}"

  patch_coredns "$cluster_name" "$docker_network"
}

# Port-forward agentgateway, check vicegerent-mcp is running, run a test script,
# then tear everything down. Used by `test gateway` and `test policies`.
run_with_portforward() {
  local script="$1"; shift

  # Check vicegerent-mcp is running
  if ! "$REPO_ROOT/vicegerent-mcp" status >/dev/null 2>&1; then
    echo "ERROR: vicegerent-mcp is not running. Start it first: ./vicegerent-mcp start" >&2
    exit 1
  fi

  require_kube_context "kind-vicegerent"

  # Port-forward agentgateway. PF_PID is global on purpose: the EXIT trap fires at
  # script scope, after this function returns, where a `local` would be unset (and
  # would trip `set -u`). The trap is the single teardown path.
  kubectl --context kind-vicegerent -n agentgateway-system \
    port-forward svc/agentgateway-proxy 8080:80 >/dev/null 2>&1 &
  PF_PID=$!
  trap 'kill "${PF_PID:-}" 2>/dev/null || true' EXIT INT TERM

  # Wait for port to open (max 15s). Use an assignment, not ((i++)) — under `set -e`
  # ((i++)) returns non-zero when i is 0 and would abort on the first iteration.
  local i=0
  while ! python3 -c "import socket; s=socket.create_connection(('127.0.0.1',8080),0.25); s.close()" 2>/dev/null; do
    i=$((i + 1))
    if [[ $i -ge 60 ]]; then
      echo "ERROR: agentgateway port-forward did not become ready after 15s" >&2
      exit 1
    fi
    sleep 0.25
  done

  # `|| rc=$?` so a failing test doesn't abort under `set -e` before teardown runs.
  export GATEWAY_URL="http://localhost:8080"
  local rc=0
  "$script" "$@" || rc=$?
  kill "${PF_PID:-}" 2>/dev/null || true
  trap - EXIT INT TERM
  return $rc
}

case "${1:-}" in
  start)
    shift
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      echo "vicegerent start — start the Kind cluster, then bring up the host ToolHive stack"
      echo "  1. docker start vicegerent-control-plane   (start the Kind node container)"
      echo "  2. ./vicegerent-mcp start                   (ToolHive workloads + vMCP + ghostunnel; add --caffeinate to keep macOS awake)"
      echo "  Extra args pass through to 'vicegerent-mcp start' (e.g. --caffeinate [--always])."
      exit 0
    fi
    echo "${B}Starting Kind cluster…${N}"
    docker start vicegerent-control-plane >/dev/null 2>&1 || true
    echo "${B}Starting host MCP stack…${N}"
    exec "$REPO_ROOT/vicegerent-mcp" start "$@"
    ;;
  stop)
    shift
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      echo "vicegerent stop — stop the host ToolHive stack, then stop the Kind cluster"
      echo "  1. ./vicegerent-mcp stop                    (tears down the supervised vMCP + ghostunnel + caffeinate, and stops the ToolHive workloads)"
      echo "  2. docker stop vicegerent-control-plane     (stop the Kind node container to free CPU)"
      exit 0
    fi
    echo "${B}Stopping host MCP stack…${N}"
    "$REPO_ROOT/vicegerent-mcp" stop "$@"
    echo "${B}Stopping Kind cluster…${N}"
    exec docker stop vicegerent-control-plane
    ;;
  cluster)
    shift
    case "${1:-}" in
      setup)
        shift
        [[ "${1:-}" == "--help" ]] && { cluster_usage; exit 0; }
        cluster_setup "$@"
        ;;
      pause)
        shift
        [[ "${1:-}" == "--help" ]] && { echo "docker stop vicegerent-control-plane"; exit 0; }
        exec docker stop vicegerent-control-plane "$@"
        ;;
      resume)
        shift
        [[ "${1:-}" == "--help" ]] && { echo "docker start vicegerent-control-plane"; exit 0; }
        exec docker start vicegerent-control-plane "$@"
        ;;
      status)
        shift
        [[ "${1:-}" == "--help" ]] && { echo "kubectl --context kind-vicegerent get nodes"; exit 0; }
        require_kube_context "kind-vicegerent"
        exec kubectl --context kind-vicegerent get nodes "$@"
        ;;
      --help|-h|"")
        cluster_usage
        exit 0
        ;;
      *)
        echo "unknown cluster subcommand: $1" >&2
        cluster_usage >&2
        exit 1
        ;;
    esac
    ;;
  secrets)
    shift
    case "${1:-}" in
      setup)
        shift
        case "${1:-}" in
          platform)
            shift
            exec "$REPO_ROOT/scripts/install/setup-secrets-platform.sh" "$@"
            ;;
          agent)
            shift
            [[ $# -ge 1 ]] || { echo "usage: vicegerent secrets setup agent <agent-name> [-y|--yes]" >&2; exit 2; }
            exec "$REPO_ROOT/scripts/install/setup-secrets-agent.sh" "$@"
            ;;
          --help|-h|"")
            echo "vicegerent secrets setup platform            →  scripts/install/setup-secrets-platform.sh"
            echo "vicegerent secrets setup agent <agent-name>  →  scripts/install/setup-secrets-agent.sh"
            exit 0
            ;;
          *)
            echo "unknown secrets setup target: $1 (expected 'platform' or 'agent')" >&2
            exit 1
            ;;
        esac
        ;;
      --help|-h|"")
        echo "vicegerent secrets setup platform            →  platform-wide Kubernetes Secrets + host ghostunnel material"
        echo "vicegerent secrets setup agent <agent-name>  →  per-agent Kubernetes Secrets"
        exit 0
        ;;
      *)
        echo "unknown secrets subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  bootstrap)
    shift
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      echo "vicegerent bootstrap — bootstrap Flux against this repo"
      echo "  Idempotent. Flags: -y/--yes, --reseed-secrets."
      echo "  Env: KUBE_CONTEXT REPO_URL BRANCH CLUSTER_PATH PRIVATE_KEY_FILE"
      exit 0
    fi
    exec "$REPO_ROOT/scripts/install/install.sh" "$@"
    ;;
  agent)
    shift
    case "${1:-}" in
      dashboard)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent agent dashboard <agent-name> — open the agent dashboard in browser"
          exit 0
        fi
        [[ $# -ge 1 ]] || { echo "usage: vicegerent agent dashboard <agent-name>" >&2; exit 2; }
        AGENT="$(echo "$1" | tr '[:upper:]' '[:lower:]')"; shift
        exec "$REPO_ROOT/scripts/dashboard/open-dashboard.sh" "$AGENT" "$@"
        ;;
      creds)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent agent creds <agent-name> — print credentials and dashboard URL"
          exit 0
        fi
        [[ $# -ge 1 ]] || { echo "usage: vicegerent agent creds <agent-name>" >&2; exit 2; }
        AGENT="$(echo "$1" | tr '[:upper:]' '[:lower:]')"; shift
        "$REPO_ROOT/scripts/dashboard/dashboard-basic-cred.sh" "$AGENT" "$@"
        ;;
      --help|-h|"")
        echo "vicegerent agent dashboard <name>  →  open agent dashboard"
        echo "vicegerent agent creds <name>      →  show credentials and URL"
        exit 0
        ;;
      *)
        echo "unknown agent subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  test)
    shift
    case "${1:-}" in
      gateway)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent test gateway — probe MCP endpoints (auto port-forwards agentgateway, requires vicegerent-mcp running)"
          exit 0
        fi
        run_with_portforward "$REPO_ROOT/scripts/test-mcp-gateway.sh" "$@"
        ;;
      policies)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent test policies — run MCP policy enforcement tests (auto port-forwards agentgateway, requires vicegerent-mcp running)"
          exit 0
        fi
        run_with_portforward "$REPO_ROOT/scripts/test-mcp-policies.sh" "$@"
        ;;
      egress)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent test egress <agent-name> — run the egress-proxy redaction/enforcement tests against a running agent sandbox"
          exit 0
        fi
        [[ $# -ge 1 ]] || { echo "usage: vicegerent test egress <agent-name>" >&2; exit 2; }
        AGENT="$(echo "$1" | tr '[:upper:]' '[:lower:]')"; shift
        AGENT_LABEL="$AGENT" exec "$REPO_ROOT/scripts/test-egress-redaction.sh" "$@"
        ;;
      --help|-h|"")
        echo "vicegerent test gateway              →  scripts/test-mcp-gateway.sh"
        echo "vicegerent test policies             →  scripts/test-mcp-policies.sh"
        echo "vicegerent test egress <agent-name>  →  scripts/test-egress-redaction.sh"
        exit 0
        ;;
      *)
        echo "unknown test subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  mcp)
    shift
    case "${1:-}" in
      setup)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent mcp setup — set up all host-side MCP prerequisites"
          echo "  Installs Homebrew packages (thv, ghostunnel, supervisor), the Python venv,"
          echo "  and prints thv secrets-provider + API-key guidance."
          echo "  Flags: -y/--yes"
          exit 0
        fi
        exec "$REPO_ROOT/scripts/host/setup-host-mcp" "$@"
        ;;
      configure|servers)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent mcp configure — interactively enable/skip each MCP server + set its secrets"
          echo "  MCP servers are off by default; this walks through them one at a time."
          exit 0
        fi
        exec "$REPO_ROOT/vicegerent-mcp" configure "$@"
        ;;
      tui)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent mcp tui — open the host stack TUI dashboard (textual)"
          exit 0
        fi
        exec "$REPO_ROOT/vicegerent-mcp" tui "$@"
        ;;
      --help|-h|"")
        echo "vicegerent mcp setup      →  scripts/host/setup-host-mcp"
        echo "vicegerent mcp configure  →  enable/skip each MCP server + set secrets"
        echo "vicegerent mcp tui        →  vicegerent-mcp tui  (host stack dashboard)"
        exit 0
        ;;
      *)
        echo "unknown mcp subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  slack)
    shift
    case "${1:-}" in
      manifest)
        shift
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
          echo "vicegerent slack manifest — generate a Hermes Slack app manifest for a named bot"
          echo "  Usage: vicegerent slack manifest <name> [output-file]"
          echo "  Example: vicegerent slack manifest \"Hermes Infra\" infra-manifest.yaml"
          exit 0
        fi
        exec "$REPO_ROOT/scripts/slack/generate-manifest.sh" "$@"
        ;;
      --help|-h|"")
        echo "vicegerent slack manifest  →  scripts/slack/generate-manifest.sh"
        exit 0
        ;;
      *)
        echo "unknown slack subcommand: $1" >&2
        exit 1
        ;;
    esac
    ;;
  help|--help|-h|"")
    usage
    exit 0
    ;;
  *)
    echo "unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
