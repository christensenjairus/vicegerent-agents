{
  "proxy": {
    "listen_host": "127.0.0.1",
    "proxy_port": 3663,
    "filtered_port": 3777,
    "disable_stdio_retries": true
  },
  "servers": {
    "kubernetes": {
      "enabled": true,
      "mode": "local-stdio",
      "name": "Kubernetes (all contexts)",
      "command": "npx",
      "args": ["-y", "kubernetes-mcp-server@0.0.63", "--read-only"],
      "env": {
        "KUBECONFIG": "~/.kube/config"
      }
    },
    "notion": {
      "enabled": true,
      "mode": "remote-oauth",
      "name": "Notion",
      "url": "https://mcp.notion.com/mcp",
      "command": "npx",
      "args": ["-y", "mcp-remote@0.1.38", "https://mcp.notion.com/mcp"]
    },
    "linear": {
      "enabled": true,
      "mode": "remote-oauth",
      "name": "Linear",
      "url": "https://mcp.linear.app/mcp",
      "command": "npx",
      "args": ["-y", "mcp-remote@0.1.38", "https://mcp.linear.app/mcp"]
    }
  }
}
